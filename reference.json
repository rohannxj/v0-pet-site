{
  "design_system": {
    "name": "Pet Product Grid - Clean E-commerce",
    "version": "1.0",
    "theme": "minimal-product-showcase",
    
    "color_palette": {
      "primary": {
        "sage_green": "#6B7F6E",
        "olive_accent": "#7A8C6F",
        "description": "Primary brand color for active states and accents"
      },
      "background": {
        "warm_cream": "#F5F1E8",
        "off_white": "#FAF8F3",
        "card_white": "#FFFFFF",
        "description": "Warm, organic background tones"
      },
      "text": {
        "primary_black": "#1A1A1A",
        "secondary_gray": "#5A5A5A",
        "light_gray": "#8A8A8A",
        "description": "Text hierarchy with clear contrast"
      },
      "interactive": {
        "checkmark_green": "#4A7C59",
        "star_rating": "#2C3E2E",
        "border_gray": "#D4D0C8",
        "description": "Interactive element colors"
      },
      "decorative": {
        "natural_browns": ["#8B6F47", "#A0826D", "#6F5643"],
        "muted_reds": "#A94442",
        "forest_green": "#3D5A3E",
        "description": "Colors for decorative botanical elements"
      }
    },
    
    "typography": {
      "primary_font": {
        "family": "Sans-serif - Bold, Modern",
        "characteristics": "Strong, readable, slightly condensed",
        "usage": "Headings, product titles, prices"
      },
      "secondary_font": {
        "family": "Sans-serif - Regular weight",
        "characteristics": "Clean, legible, neutral",
        "usage": "Body text, descriptions, metadata"
      },
      "type_scale": {
        "section_heading": {
          "size": "28-36px",
          "weight": "700-800",
          "letter_spacing": "-0.01em",
          "line_height": "1.2"
        },
        "section_subtitle": {
          "size": "14-16px",
          "weight": "400",
          "color": "secondary_gray",
          "line_height": "1.5"
        },
        "product_title": {
          "size": "16-18px",
          "weight": "600-700",
          "line_height": "1.3",
          "letter_spacing": "-0.005em"
        },
        "product_price": {
          "size": "20-24px",
          "weight": "700",
          "line_height": "1.2"
        },
        "metadata": {
          "size": "12-14px",
          "weight": "400",
          "color": "light_gray",
          "line_height": "1.4"
        },
        "feature_list": {
          "size": "13-15px",
          "weight": "400",
          "line_height": "1.6"
        }
      }
    },
    
    "layout_structure": {
      "section_header": {
        "layout": "space_between",
        "elements": {
          "left": {
            "content": ["main_heading", "subtitle_metadata"],
            "alignment": "left"
          },
          "right": {
            "content": "filter_pills",
            "alignment": "right"
          }
        },
        "margin_bottom": "24-32px"
      },
      
      "product_grid": {
        "display": "grid",
        "columns": {
          "mobile": "1",
          "tablet": "2",
          "desktop": "4",
          "large_desktop": "4-5"
        },
        "gap": "16-24px",
        "container_padding": "20-40px",
        "max_width": "1400px"
      },
      
      "decorative_elements": {
        "floating_seeds": {
          "position": "fixed_or_absolute",
          "placement": "top_right_corner",
          "behavior": "scattered_natural_pattern",
          "z_index": "background_layer"
        }
      }
    },
    
    "components": {
      "product_card": {
        "structure": {
          "layout": "vertical_stack",
          "sections": [
            "image_container",
            "brand_label",
            "product_title",
            "rating_section",
            "price_display",
            "feature_list"
          ]
        },
        
        "card_container": {
          "background": "#FFFFFF",
          "border": "1-2px solid",
          "border_color": "#D4D0C8",
          "border_radius": "12-16px",
          "padding": "16-20px",
          "shadow": "none_or_very_subtle",
          "hover_state": {
            "transform": "translateY(-4px)",
            "shadow": "0 8px 24px rgba(0,0,0,0.08)",
            "border_color": "slightly_darker"
          }
        },
        
        "image_section": {
          "aspect_ratio": "1:1_or_4:5",
          "padding": "16-20px",
          "background": "transparent_or_subtle_gray",
          "border_radius": "8-12px",
          "margin_bottom": "12-16px",
          "object_fit": "contain",
          "badge_overlay": {
            "position": "top_right",
            "style": "circular_seal",
            "size": "48-60px",
            "background": "gold_or_branded_color",
            "content": "award_certification_indicator"
          }
        },
        
        "brand_label": {
          "size": "12-13px",
          "weight": "400",
          "color": "secondary_gray",
          "text_transform": "none",
          "margin_bottom": "4-6px"
        },
        
        "product_title": {
          "size": "16-18px",
          "weight": "600-700",
          "color": "primary_black",
          "line_height": "1.3",
          "margin_bottom": "8-12px",
          "max_lines": "2",
          "overflow": "ellipsis"
        },
        
        "rating_display": {
          "layout": "horizontal",
          "elements": {
            "stars": {
              "count": "5",
              "size": "16-18px",
              "filled_color": "primary_black_or_dark_green",
              "empty_color": "light_gray_outline",
              "spacing": "2-4px"
            },
            "rating_text": {
              "size": "12-14px",
              "color": "light_gray",
              "format": "£XX.XX savings_or_XX_ratings",
              "margin_left": "8px"
            }
          },
          "margin_bottom": "12-16px"
        },
        
        "feature_list": {
          "layout": "vertical_stack",
          "spacing": "6-8px",
          "margin_bottom": "16-20px",
          "item": {
            "structure": "icon_plus_text",
            "icon": {
              "type": "checkmark_circle",
              "size": "16-18px",
              "color": "sage_green",
              "style": "outlined_or_filled"
            },
            "text": {
              "size": "13-15px",
              "weight": "400",
              "color": "secondary_gray",
              "margin_left": "8-10px"
            }
          }
        },
        
        "price_display": {
          "size": "20-24px",
          "weight": "700",
          "color": "primary_black",
          "format": "£XX.XX",
          "alignment": "left"
        }
      },
      
      "filter_pills": {
        "layout": "horizontal_row",
        "spacing": "8-12px",
        "pill_style": {
          "padding": "8-12px 16-20px",
          "border_radius": "6-8px",
          "border": "1px solid",
          "font_size": "13-15px",
          "font_weight": "500",
          "text_transform": "capitalize"
        },
        "states": {
          "inactive": {
            "background": "transparent_or_white",
            "border_color": "#D4D0C8",
            "text_color": "secondary_gray"
          },
          "active": {
            "background": "#6B7F6E",
            "border_color": "#6B7F6E",
            "text_color": "#FFFFFF"
          },
          "hover": {
            "border_color": "darker_gray",
            "background": "subtle_hover"
          }
        }
      },
      
      "cta_button": {
        "primary": {
          "padding": "12-16px 32-48px",
          "border_radius": "6-8px",
          "border": "1-2px solid #D4D0C8",
          "background": "transparent_or_white",
          "text_color": "primary_black",
          "font_size": "14-16px",
          "font_weight": "600",
          "hover": {
            "background": "#6B7F6E",
            "border_color": "#6B7F6E",
            "text_color": "#FFFFFF"
          }
        },
        "position": "bottom_center_of_section",
        "margin_top": "32-48px"
      },
      
      "rating_stars": {
        "style": "filled_solid",
        "icon_type": "star",
        "size": "16-18px",
        "color": "#2C3E2E",
        "spacing": "2-4px",
        "display": "inline_flex"
      },
      
      "checkmark_icon": {
        "style": "circle_outline_with_check",
        "size": "16-18px",
        "stroke_width": "1.5-2px",
        "color": "#4A7C59",
        "check_style": "simple_tick"
      },
      
      "badge_seal": {
        "shape": "circle",
        "size": "48-60px",
        "style": "starburst_or_seal",
        "colors": ["gold", "green", "branded"],
        "position": "top_right_overlay",
        "content": "icon_or_text",
        "shadow": "subtle_drop_shadow"
      }
    },
    
    "visual_principles": {
      "aesthetic": "clean_minimal_organic",
      "mood": "trustworthy_natural_accessible",
      
      "photography_style": {
        "background": "pure_white_or_transparent",
        "lighting": "soft_even_studio_lighting",
        "composition": "centered_product_focus",
        "styling": "minimal_with_natural_props",
        "color_grading": "accurate_natural_colors"
      },
      
      "grid_system": {
        "columns": "12_column_grid",
        "gutter": "16-24px",
        "margin": "20-40px",
        "alignment": "strict_grid_alignment"
      },
      
      "spacing": {
        "philosophy": "consistent_8px_system",
        "card_internal_padding": "16-20px",
        "section_spacing": "48-64px",
        "element_spacing": "12-16px",
        "micro_spacing": "4-8px"
      },
      
      "borders_and_edges": {
        "card_radius": "12-16px",
        "button_radius": "6-8px",
        "pill_radius": "6-8px",
        "image_radius": "8-12px",
        "border_weight": "1-2px",
        "border_style": "solid",
        "border_color": "subtle_neutral_gray"
      },
      
      "elevation": {
        "cards_default": "flat_with_border",
        "cards_hover": "subtle_lift_8px",
        "buttons": "no_shadow",
        "overlays": "medium_shadow"
      }
    },
    
    "content_patterns": {
      "product_title_formula": {
        "max_length": "40-60_characters",
        "format": "descriptive_name",
        "capitalization": "title_case",
        "lines": "1-2_lines_max"
      },
      
      "price_format": {
        "currency_symbol": "before_number",
        "decimal_places": "2",
        "size_emphasis": "larger_than_body_text",
        "weight": "bold"
      },
      
      "feature_list": {
        "items_count": "2-3_per_card",
        "format": "short_benefit_phrases",
        "length": "2-4_words_per_item",
        "style": "checkmark_prefix"
      },
      
      "metadata": {
        "format": "X_items_·_details",
        "separator": "·_or_-",
        "color": "light_gray",
        "size": "small"
      }
    },
    
    "interaction_design": {
      "hover_states": {
        "cards": {
          "transform": "translateY(-4px)",
          "shadow": "increase",
          "border": "subtle_color_shift",
          "transition": "200-300ms_ease"
        },
        "buttons": {
          "background": "fill_with_brand_color",
          "text_color": "invert_to_white",
          "scale": "none_or_subtle_1.02",
          "transition": "200ms_ease"
        },
        "filter_pills": {
          "border": "darken",
          "background": "subtle_tint",
          "transition": "150ms_ease"
        }
      },
      
      "active_states": {
        "filters": "filled_background_with_white_text",
        "cards": "no_persistent_active_state",
        "buttons": "pressed_scale_0.98"
      },
      
      "transitions": {
        "default_duration": "200-300ms",
        "easing": "ease_or_ease_out",
        "properties": ["transform", "box-shadow", "background", "border-color", "color"]
      }
    },
    
    "responsive_behavior": {
      "breakpoints": {
        "mobile": "320-640px",
        "tablet": "641-1024px",
        "desktop": "1025-1440px",
        "large": "1441px+"
      },
      
      "grid_adaptations": {
        "mobile": {
          "columns": "1",
          "padding": "16-20px",
          "card_size": "full_width"
        },
        "tablet": {
          "columns": "2",
          "padding": "24-32px",
          "gap": "16-20px"
        },
        "desktop": {
          "columns": "4",
          "padding": "32-40px",
          "gap": "20-24px"
        }
      },
      
      "header_adaptations": {
        "mobile": "stack_vertically",
        "tablet": "filters_below_heading",
        "desktop": "side_by_side"
      }
    },
    
    "accessibility": {
      "contrast_ratios": "WCAG_AA_minimum",
      "focus_indicators": "visible_outline_2px_brand_color",
      "touch_targets": "minimum_44x44px",
      "alt_text": "required_for_all_images",
      "aria_labels": "on_interactive_elements"
    },
    
    "decorative_system": {
      "floating_elements": {
        "type": "seeds_and_botanical_pieces",
        "treatment": "photorealistic_or_illustrated",
        "placement": "corners_edges_scattered",
        "density": "sparse_4-8_elements",
        "scale_variation": "yes",
        "rotation": "random_natural",
        "opacity": "60-100%",
        "z_index": "behind_content",
        "behavior": "static_or_subtle_animation"
      }
    },
    
    "usage_guidelines": {
      "when_to_use": [
        "Product listing pages and category grids",
        "E-commerce product showcases",
        "Marketplace and catalog displays",
        "Pet products, natural goods, lifestyle items",
        "Search results and filtered product views"
      ],
      
      "key_differentiators": [
        "Clean white cards with subtle borders - no heavy shadows",
        "Consistent grid system with equal card heights",
        "Checkmark-based feature lists within cards",
        "Filter pills with toggle states in header",
        "Award/certification badges overlaid on product images",
        "Warm cream background with white card contrast",
        "Botanical decorative elements in corners"
      ],
      
      "implementation_notes": [
        "Cards should have equal heights using flexbox or grid",
        "Product images must be on pure white backgrounds",
        "Use 8px spacing system for internal consistency",
        "Filter pills should have clear active/inactive states",
        "Rating stars should align with accompanying text",
        "Hover states are essential for cards and buttons",
        "Feature lists should be 2-3 items max to maintain card height",
        "Price should be the most prominent text element on card",
        "Decorative seeds/elements should not interfere with content",
        "Maintain strict alignment across all grid columns"
      ]
    },
    
    "component_hierarchy": {
      "information_priority": [
        "1_product_image",
        "2_product_title",
        "3_price",
        "4_rating",
        "5_feature_benefits",
        "6_brand_metadata"
      ],
      
      "visual_weight": {
        "highest": "price_and_product_image",
        "high": "product_title",
        "medium": "rating_stars_and_features",
        "low": "brand_and_metadata"
      }
    }
  }
}